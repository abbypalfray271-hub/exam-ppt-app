/**
 * 考题内容解析引擎 (State-Machine Tokenizer)
 * 职责：逐字符扫描净化后的文本，生成结构化的 Token 数组。
 * 彻底杜绝正则表达式在面对复杂嵌套、换行公式时的“哑火”或“截断”现象。
 */

export type TokenType = 'text' | 'math' | 'cloze' | 'image' | 'option';

export interface Token {
  type: TokenType;
  content: string;
  originalLabel?: string; // 仅用于 option 类型
}

export const parseExamContent = (text: string): Token[] => {
  const tokens: Token[] = [];
  let i = 0;
  let currentText = '';

  const flushText = () => {
    if (currentText) {
      // 在文本块中进一步识别选项 A. B. C. D.
      // 这里的逻辑可以根据 Step 5 进一步精细化
      tokens.push({ type: 'text', content: currentText });
      currentText = '';
    }
  };

  while (i < text.length) {
    // 1. 尝试匹配数学公式 $ ... $ 或 $$ ... $$
    if (text[i] === '$') {
      flushText();
      let start = i;
      let isDisplay = text[i + 1] === '$';
      let delimiter = isDisplay ? '$$' : '$';
      i += delimiter.length;
      
      let endIdx = text.indexOf(delimiter, i);
      if (endIdx !== -1) {
        tokens.push({ 
          type: 'math', 
          content: text.slice(start, endIdx + delimiter.length) 
        });
        i = endIdx + delimiter.length;
        continue;
      } else {
        // 未闭合，当作普通文本处理
        currentText += delimiter;
        continue;
      }
    }

    // 1.5. 尝试匹配“裸露”的 LaTeX 环境 (Naked environment)
    // 识别 \begin{env} ... \end{env}
    if (text[i] === '\\' && text.slice(i, i + 6) === '\\begin') {
      const match = text.slice(i).match(/^\\begin\{([a-zA-Z*]+)\}/);
      if (match) {
        const envName = match[1];
        const endTag = `\\end{${envName}}`;
        const endTagIdx = text.indexOf(endTag, i);
        
        if (endTagIdx !== -1) {
          flushText();
          const fullContent = text.slice(i, endTagIdx + endTag.length);
          tokens.push({
            type: 'math',
            content: fullContent
          });
          i = endTagIdx + endTag.length;
          continue;
        }
      }
    }

    // 2. 尝试匹配填空标记 {{ ... }}
    if (text[i] === '{' && text[i + 1] === '{') {
      flushText();
      let endIdx = text.indexOf('}}', i + 2);
      if (endIdx !== -1) {
        tokens.push({ 
          type: 'cloze', 
          content: text.slice(i, endIdx + 2) 
        });
        i = endIdx + 2;
        continue;
      }
    }

    // 3. 尝试匹配资源占位符 [附图] / [表格]
    if (text[i] === '[') {
      const match = text.slice(i).match(/^(\[附图\]|\[表格\])/);
      if (match) {
        flushText();
        tokens.push({ type: 'image', content: match[1] });
        i += match[1].length;
        continue;
      }
    }

    // 4. 尝试匹配选项 A. B. C. D. (仅匹配开头)
    // 启发式：必须是行首或前面有空白/换行
    const isStartOfLine = i === 0 || text[i-1] === '\n' || text[i-1] === ' ';
    if (isStartOfLine) {
      const optMatch = text.slice(i).match(/^([A-D][\.．]\s*)/);
      if (optMatch) {
        flushText();
        tokens.push({ type: 'option', content: optMatch[1], originalLabel: optMatch[1] });
        i += optMatch[1].length;
        continue;
      }
    }

    // 默认作为普通文本
    currentText += text[i];
    i++;
  }

  flushText();
  return tokens;
};
